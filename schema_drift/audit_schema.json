{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AuditLog",
  "description": "Schema for the schema-drift audit log file",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["event", "timestamp"],
    "additionalProperties": false,
    "properties": {
      "event": {
        "type": "string",
        "description": "Name of the audited event",
        "examples": ["snapshot_saved", "diff_run", "baseline_set"]
      },
      "timestamp": {
        "type": "string",
        "format": "date-time",
        "description": "ISO-8601 UTC timestamp of the event"
      },
      "details": {
        "type": "object",
        "description": "Arbitrary key/value pairs providing event context",
        "additionalProperties": {
          "type": ["string", "number", "boolean", "null"]
        }
      }
    }
  }
}
